# Server
PORT=5000
NODE_ENV=development

# Database — MongoDB Atlas free tier (M0) recommended (replica set required for transactions)
# Get yours at: https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/expert-booking?retryWrites=true&w=majority

# CORS — comma-separated list of allowed origins (web + mobile dev)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:19006

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
