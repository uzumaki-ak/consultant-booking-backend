{
  "name": "expert-booking-backend",
  "version": "1.0.0",
  "description": "Real-time expert session booking backend with Socket.io and double-booking prevention",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx src/config/seed.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "express",
    "mongodb",
    "socket.io",
    "typescript",
    "booking"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.3.0",
    "mongodb": "^7.2.0",
    "mongoose": "^8.9.0",
    "morgan": "^1.10.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
